# ---- LLM provider (provider-agnostic via LiteLLM) ----
# LLM_MODEL selects provider + model as "<provider>/<model>". Examples:
#   anthropic/claude-opus-4-8   openai/gpt-4o-mini   gemini/gemini-2.5-flash   ollama/llama3.1
LLM_MODEL=openai/gpt-4.1-mini

# Set the key for whichever provider LLM_MODEL points at (ollama needs none):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=
OLLAMA_API_BASE=http://localhost:11434

# Extended thinking (Anthropic only) on the final recommendation step (true/false).
CLAUDE_THINKING=false
# Back-compat: used only if LLM_MODEL is unset (-> anthropic/<CLAUDE_MODEL>).
CLAUDE_MODEL=claude-opus-4-8

# ---- PostgreSQL + pgvector ----
# Shared cloud DB — no local setup needed. Just copy these values as-is.
PGHOST=34.10.133.69
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=rag123

# ---- Embeddings (local, no API key) ----
# auto = try fastembed then fall back to hashing; fastembed = ONNX model (needs CDN access);
# hashing = no download, works on locked-down networks.
EMBED_BACKEND=auto
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384
